# =========================
# Runtime and image settings
# =========================
APP_MODE=development
NODE_BASE_IMAGE=node:20-alpine

MONGO_IMAGE=mongo:7.0
CONFIG_IMAGE=todo-list2-config:latest
DB_IMAGE=todo-list2-db:latest
BACK_IMAGE=todo-list2-back:latest
FRONT_IMAGE=todo-list2-front:latest

MONGO_CONTAINER_NAME=todo-mongo
CONFIG_CONTAINER_NAME=todo-config
DB_CONTAINER_NAME=todo-db
BACK_CONTAINER_NAME=todo-back
FRONT_CONTAINER_NAME=todo-front

# =========================
# Exposed host ports
# =========================
PORT_CONFIG=3011
PORT_SERVER=3010
PORT_DB=3012
PORT_FRONT=3013
MONGO_PORT=27017

# =========================
# App network settings used by config service
# =========================
PROTOCOL=http
IP_SERVER=back
IP_DB=db
IP_FRONT=localhost

# MongoDB connection used by back service
# For local Docker use:
DB_URL=mongodb://mongo:27017/todo_list
# Example external URI (replace with real value in private docker.env):
# DB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# =========================
# Internal/external config endpoints
# =========================
# Used by back and db containers to reach config service in Docker network
SERVER_CONFIG_URL_DOCKER=http://config:3011/config

# Used by browser (React app) to reach config via host mapped port
REACT_APP_SERVER_CONFIG_URL=http://localhost:3011/config
